# PokeFolio prod env — Phase 1-6
#
# 실제 .env.prod는 서버에만 두고 git commit 금지.
# .gitignore에 .env 패턴 이미 등록됨. 이 example만 tracked.
#
# 사용:
#   1. 서버 /opt/pokefolio/.env.prod 로 cp + chmod 600
#   2. 모든 REPLACE_ME 값을 실제 값으로 교체
#   3. docker compose --env-file /opt/pokefolio/.env.prod -f docker-compose.prod.yml up -d

# ───────────── Spring profile ─────────────
SPRING_PROFILES_ACTIVE=prod

# ───────────── Database (PostgreSQL) ─────────────
# Spring JDBC
DB_URL=jdbc:postgresql://postgres:5432/pokemon_card_db
DB_USER=nightfury
DB_PASSWORD=REPLACE_ME_STRONG_PASSWORD_MIN_16_CHARS

# Python (psycopg2 — 같은 DB 공유)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=pokemon_card_db
# DB_USER / DB_PASSWORD는 위 Spring 값 재사용 (docker-compose env 주입)

# ───────────── JWT (Phase 1-2 fail-fast) ─────────────
# 32 bytes 이상 필수. 예: openssl rand -base64 48
JWT_SECRET=REPLACE_ME_AT_LEAST_32_BYTES_OPENSSL_RAND_BASE64_48
JWT_EXPIRATION_MS=2592000000

# ───────────── OAuth / 외부 API ─────────────
GOOGLE_CLIENT_ID=REPLACE_ME_GOOGLE_OAUTH_CLIENT_ID
PTCG_API_KEY=REPLACE_ME_POKEMONTCG_IO_API_KEY
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=

# ───────────── 운영 알림 ─────────────
# PriceSyncScheduler 실패 시 인앱 알림 받을 user_id
OPS_ADMIN_USER_ID=

# ───────────── Python 실행 경로 (Phase 1-1) ─────────────
PYTHON_SYSTEM=/usr/local/bin/python3
PYTHON_VENV_KREAM=/app/python/.venv_kream/bin/python
PYTHON_SCRIPTS_DIR=/app/python

# ───────────── Service URLs (docker internal network) ─────────────
GRADING_SERVICE_URL=http://grading:8081
SCANNER_BASE_URL=http://scanner:8082

# ───────────── CORS (Phase 1-3) ─────────────
# comma-separated. wildcard 금지. iOS/Android 앱은 CORS 미적용이지만 swagger/admin web 대비.
CORS_ALLOWED_ORIGINS=https://api.pokefolio.kr,https://admin.pokefolio.kr

# ───────────── 인증 toggle (Phase 1-3 / Codex Critical 4·High 6) ─────────────
# prod에선 3개 모두 강제. StartupValidator가 시작 시점에 검증 (false면 fail).
ADMIN_AUTH_ENABLED=true
API_AUTH_ENFORCED=true
DEV_LOGIN_ENABLED=false   # /api/auth/dev/** prod 차단

# ───────────── 이미지 저장소 (Phase 1-7) ─────────────
# type=s3 권장. local은 fallback.
IMAGE_STORAGE_TYPE=s3
LOCAL_UPLOAD_DIR=/opt/pokefolio/data/uploads

AWS_S3_BUCKET=pokefolio-beta-assets-759135635310-ap-northeast-2-an
AWS_S3_REGION=ap-northeast-2
# AWS S3 default endpoint 시 빈값. MinIO/R2 등 S3-compatible은 URL 명시.
AWS_S3_ENDPOINT=

# IAM user (pokefolio-s3-uploader). 채팅/git 절대 출력 X.
AWS_ACCESS_KEY_ID=REPLACE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_ME_AWS_SECRET_ACCESS_KEY

# ───────────── 이미지 디렉터리 (Spring static handler, legacy/fallback) ─────────────
CARD_IMAGE_DIR=/opt/pokefolio/data/images/cards
TRADE_IMAGE_DIR=/opt/pokefolio/data/images/trades
ASSET_GRADING_IMAGE_DIR=/opt/pokefolio/data/images/asset-grading
