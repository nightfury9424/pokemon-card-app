# PokeFolio Environment Variables Template
#
# Usage (local):
#   cp .env.example .env
#   # 그 후 실제 값 입력 — .env는 .gitignore되어 있음
#
# Usage (production):
#   docker-compose env_file: .env
#   또는 systemd EnvironmentFile=/etc/pokefolio/.env
#
# NEVER commit .env with real secrets.

# =============================================================
# Backend (Spring Boot, port 8080)
# =============================================================

DB_URL=jdbc:postgresql://localhost:5432/pokemon_card_db
DB_USER=nightfury
DB_PASSWORD=

# JWT — 운영에서 반드시 32바이트 이상 랜덤 값 (openssl rand -base64 48)
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# Google OAuth (Identity Provider Client ID, public 가능)
GOOGLE_CLIENT_ID=

# Pokémon TCG API (선택, scrydex 우회용)
PTCG_API_KEY=

# Internal service URLs (Docker network 내부 DNS 또는 localhost)
GRADING_SERVICE_URL=http://localhost:8081
SCANNER_BASE_URL=http://localhost:8082

# Image storage paths (또는 R2/S3로 마이그레이션 시 URL prefix)
CARD_IMAGE_DIR=./images/cards
TRADE_IMAGE_DIR=./trade_images
ASSET_GRADING_IMAGE_DIR=./asset_grading_images

# Ops admin user (in-app notification 수신)
OPS_ADMIN_USER_ID=

# =============================================================
# Python cron / batch scripts (python/config.example.py 참조)
# =============================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=pokemon_card_db
# DB_USER, DB_PASSWORD는 위 백엔드와 동일 값 사용

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

EBAY_APP_ID=
EBAY_DEV_ID=
EBAY_CERT_ID=

USER_AGENT=

# =============================================================
# Scanner (FastAPI, port 8082) — env 직접 사용 안 함 (성능 튜닝만 코드 내부)
# =============================================================

# (현재 추가 env 없음)

# =============================================================
# Grading (FastAPI, port 8081) — env 직접 사용 안 함
# =============================================================

# (현재 추가 env 없음)
